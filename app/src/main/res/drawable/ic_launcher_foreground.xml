    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Group to center and scale the brand logo beautifully -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="1.1"
        android:scaleY="1.1">

