        <path
            android:fillColor="#2979FF"
            android:pathData="M34,79.5 h14 v1.5 h-14 z M34,83 h10 v1.5 h-10 z" />
        <path
            android:fillColor="#FF1744"
            android:pathData="M56,79.5 h16 v1.5 h-16 z M56,83 h12 v1.5 h-12 z" />

