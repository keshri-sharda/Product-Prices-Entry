        <path
            android:pathData="M16,70 H92 V74 H16 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="16"
                    android:startY="70"
                    android:endX="92"
                    android:endY="74"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#FF1744" />
                    <item android:offset="1.0" android:color="#B71C1C" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Main Counter Base Body (Vibrant Blue Panel) -->
        <path
            android:pathData="M20,74 H88 V88 H20 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="20"
                    android:startY="74"
                    android:endX="88"
                    android:endY="88"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#2979FF" />
                    <item android:offset="1.0" android:color="#1565C0" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Clean, polished, white Price Chalkboard on the Counter front -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M30,77.5 c0,-1 1,-2 2,-2 h44 c1,0 2,1 2,2 v7 c0,1 -1,2 -2,2 h-44 c-1,0 -2,-1 -2,-2 z" />
            
