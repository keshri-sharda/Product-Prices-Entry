            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="37"
                    android:startY="32"
                    android:endX="54"
                    android:endY="44"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#2979FF" />
                    <item android:offset="1.0" android:color="#1565C0" />
