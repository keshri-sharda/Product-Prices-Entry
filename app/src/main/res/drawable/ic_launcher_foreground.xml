        <!-- Cute smiling eyes & happy mouth -->
        <path
            android:strokeColor="#1A237E"
            android:strokeWidth="1.2"
            android:strokeLineCap="round"
            android:pathData="M50.5,48 Q51.5,46.5 52.5,48" /> <!-- Smile left eye -->
        <path
            android:strokeColor="#1A237E"
            android:strokeWidth="1.2"
            android:strokeLineCap="round"
            android:pathData="M55.5,48 Q56.5,46.5 57.5,48" /> <!-- Smile right eye -->
