                <gradient
                    android:startX="20"
                    android:startY="32"
                    android:endX="37"
                    android:endY="44"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#FF5252" />
                    <item android:offset="1.0" android:color="#D50000" />
                </gradient>
