            android:pathData="M54,54m-38,0a38,38 0 1,1 76,0a38,38 0 1,1 -76,0">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="16"
                    android:startY="16"
                    android:endX="92"
                    android:endY="92"
                    android:type="radial"
                    android:gradientRadius="38">
                    <item android:offset="0.0" android:color="#332979FF" /> <!-- Semi-translucent electric blue -->
                    <item android:offset="0.7" android:color="#22FF1744" /> <!-- Semi-translucent hot red -->
                    <item android:offset="1.0" android:color="#00000000" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- 2. RETAIL SHOP WINDOW FRAME & COLUMNS (Rich Royal Blue) -->
        <!-- Left Pillar -->
        <path
            android:pathData="M24,44 L28,44 L28,70 L24,70 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="24"
                    android:startY="44"
                    android:endX="28"
                    android:endY="70"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#2979FF" />
                    <item android:offset="1.0" android:color="#1A237E" />
