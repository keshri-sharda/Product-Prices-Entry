<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Group to perfectly scale and position the premium logo mark within the 66dp safe zone -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="1.25"
        android:scaleY="1.25">

        <!-- 1. BACKDROP SOFT GLOW (Subtle blue-teal ambiance radiating from the box) -->
        <path
            android:pathData="M58,58m-28,0a28,28 0 1,1 56,0a28,28 0 1,1 -56,0"
            android:fillColor="#0D3B82F6" />
        <path
            android:pathData="M58,58m-20,0a20,20 0 1,1 40,0a20,20 0 1,1 -40,0"
            android:fillColor="#0906B6D4" />

        <!-- 2. HIGH-CONTRAST DYNAMIC CRESCENT / SWOOSH ORBIT (Matches Logo 3's circular sweep) -->
        <!-- Thin background guide circle (subtle silver/slate line for structure) -->
        <path
            android:pathData="M 54,18 A 36,36 0 1,1 18,54"
            android:strokeWidth="0.8"
            android:strokeColor="#CBD5E1"
            android:fillColor="#00000000" />
        <!-- Deep midnight crescent arc sweeping clockwise on the right side (High Contrast Navy) -->
        <path
            android:pathData="M 79,28 A 36,36 0 1,1 28,79"
            android:strokeWidth="3.2"
            android:strokeColor="#0F172A"
            android:strokeLineCap="round"
            android:fillColor="#00000000" />
        <!-- Subtle second outer vibrant blue pilot arc -->
        <path
            android:pathData="M 83,34 A 38,38 0 0,1 64,88"
            android:strokeWidth="1.0"
            android:strokeColor="#3B82F6"
            android:strokeLineCap="round"
            android:fillColor="#00000000" />

        <!-- 3. DETAILED LEDGER BULLET ITEMS (Left side of the box representing stock listings) -->
        <!-- Green Bullet & Line -->
        <path
            android:pathData="M30,42m-1.8,0a1.8,1.8 0 1,1 3.6,0a1.8,1.8 0 1,1 -3.6,0"
            android:fillColor="#10B981" />
        <path
            android:pathData="M 35,42 L 44,42"
            android:strokeWidth="1.2"
            android:strokeColor="#475569"
            android:strokeLineCap="round" />

        <!-- Orange Bullet & Line -->
        <path
            android:pathData="M30,49m-1.8,0a1.8,1.8 0 1,1 3.6,0a1.8,1.8 0 1,1 -3.6,0"
            android:fillColor="#F59E0B" />
        <path
            android:pathData="M 35,49 L 44,49"
            android:strokeWidth="1.2"
            android:strokeColor="#475569"
            android:strokeLineCap="round" />

        <!-- Blue Bullet & Line -->
        <path
            android:pathData="M30,56m-1.8,0a1.8,1.8 0 1,1 3.6,0a1.8,1.8 0 1,1 -3.6,0"
            android:fillColor="#3B82F6" />
        <path
            android:pathData="M 35,56 L 44,56"
            android:strokeWidth="1.2"
            android:strokeColor="#475569"
            android:strokeLineCap="round" />

        <!-- 4. THE ISOMETRIC CARD BOARD BOX (Deep navy/royal blue open structure representing cargo/inventory) -->
        <group>
            <!-- Back Left Interior Wall -->
            <path
                android:pathData="M 42,54 L 58,46 L 58,62 L 42,54 Z"
                android:fillColor="#101F42" />
            <!-- Back Right Interior Wall -->
            <path
                android:pathData="M 74,54 L 58,46 L 58,62 L 74,54 Z"
                android:fillColor="#081024" />

            <!-- Outward Left Flap (Angled out) -->
            <path
                android:pathData="M 42,54 L 28,49 L 36,43 L 50,48 Z"
                android:fillColor="#1E40AF" />
            <!-- Outward Right Flap (Angled out) -->
            <path
                android:pathData="M 74,54 L 88,49 L 80,43 L 66,48 Z"
                android:fillColor="#1D4ED8" />

            <!-- Front Left Outer Face -->
            <path
                android:pathData="M 58,74 L 42,66 L 42,54 L 58,62 Z"
                android:fillColor="#2563EB" />
            <!-- Front Right Outer Face -->
            <path
                android:pathData="M 58,74 L 74,66 L 74,54 L 58,62 Z"
                android:fillColor="#1D4ED8" />

            <!-- Front-Left Rim Highlight to add a polished 3D finish -->
            <path
                android:pathData="M 42,54 L 58,62 L 74,54"
                android:strokeWidth="0.8"
                android:strokeColor="#93C5FD"
                android:fillColor="#00000000" />
        </group>

        <!-- 5. FLOATING PREMIUM ORANGE PRICE TAG (Rises dynamically from inside the box) -->
        <group>
            <!-- Tag Shadow (Drawn behind tag for lift) -->
            <path
                android:pathData="M 51,35 L 58,28 L 65,35 L 65,53 L 51,53 Z"
                android:fillColor="#40000000" />

            <!-- Tag Main Body (Vibrant safety orange representing retail pricing) -->
            <path
                android:pathData="M 50,34 L 58,26 L 66,34 L 66,52 L 50,52 Z"
                android:fillColor="#F97316" />

            <!-- White Ribbon Eyelet Ring -->
            <path
                android:pathData="M58,31m-1.2,0a1.2,1.2 0 1,1 2.4,0a1.2,1.2 0 1,1 -2.4,0"
                android:fillColor="#FFFFFF" />
            <path
                android:pathData="M58,31m-0.5,0a0.5,0.5 0 1,1 1,0a0.5,0.5 0 1,1 -1,0"
                android:fillColor="#F97316" />

            <!-- THE PREMIUM INDIAN RUPEE (₹) SYMBOL inside the tag (White, perfectly balanced and centered) -->
            <!-- Top Horizontal Bar -->
            <path
                android:pathData="M 53,37 L 63,37"
                android:strokeWidth="1.5"
                android:strokeLineCap="round"
                android:strokeColor="#FFFFFF" />

            <!-- Middle Horizontal Bar -->
            <path
                android:pathData="M 53,41 L 61,41"
                android:strokeWidth="1.5"
                android:strokeLineCap="round"
                android:strokeColor="#FFFFFF" />

            <!-- The Upper Semi-circle loop of the ₹ -->
            <path
                android:pathData="M 57.5,37 C 61,37 62.5,39 62.5,41 C 62.5,43 61,45 57.5,45"
                android:strokeWidth="1.5"
                android:strokeLineCap="round"
                android:strokeColor="#FFFFFF" />

            <!-- The base bar connecting loop to body -->
            <path
                android:pathData="M 53,45 L 57.5,45"
                android:strokeWidth="1.5"
                android:strokeLineCap="round"
                android:strokeColor="#FFFFFF" />

            <!-- The diagonal leg of the ₹ -->
            <path
                android:pathData="M 56.5,45 L 62,50.5"
                android:strokeWidth="1.5"
                android:strokeLineCap="round"
                android:strokeColor="#FFFFFF" />
        </group>

    </group>
</vector>
