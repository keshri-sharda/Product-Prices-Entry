        <path
            android:pathData="M68,54 L81,51 L87,58 L77,64 L69,59 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="68"
                    android:startY="51"
                    android:endX="87"
                    android:endY="64"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#FF5252" />
                    <item android:offset="1.0" android:color="#D50000" />
                </gradient>
            </aapt:attr>
        </path>
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M73,56.5m-1.5,0a1.5,1.5 0 1,1 3,0a1.5,1.5 0 1,1 -3,0" /> <!-- Thread hole -->
