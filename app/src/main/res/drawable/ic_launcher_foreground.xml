                    android:startY="32"
                    android:endX="71"
                    android:endY="44"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#FF5252" />
                    <item android:offset="1.0" android:color="#D50000" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Stripe 4 (Rightmost - Sapphire Blue) -->
        <path
            android:pathData="M71,32 L88,32 L88,42 C88,44.5 83.75,44.5 83.75,42 C83.75,44.5 79.5,44.5 79.5,42 C79.5,44.5 71,44.5 71,42 Z">
