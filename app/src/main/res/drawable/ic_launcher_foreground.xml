            android:strokeColor="#1A237E"
            android:strokeWidth="1.6"
            android:strokeLineCap="round"
            android:pathData="M52,51 Q54,53.5 56,51" /> <!-- Cheerful curve smile -->

        <!-- Left waving hand -->
        <path
            android:pathData="M44,61 C41,59.5 37,56 35,52 L39,50 C41,53.5 44,56.5 46,58 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="35"
                    android:startY="50"
                    android:endX="46"
                    android:endY="61"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#1565C0" />
                    <item android:offset="1.0" android:color="#0D47A1" />
                </gradient>
            </aapt:attr>
        </path>
        <path
            android:fillColor="#FFD54F"
            android:pathData="M35,52m-3,0a3,3 0 1,1 6,0a3,3 0 1,1 -6,0" />

