            android:pathData="M44,70 C44,59 47,55 54,55 C61,55 64,59 64,70 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="44"
                    android:startY="55"
                    android:endX="64"
                    android:endY="70"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#1565C0" />
                    <item android:offset="1.0" android:color="#0D47A1" />
                </gradient>
            </aapt:attr>
        </path>
        
        <!-- Red Apron Suspenders/Straps -->
        <path
            android:fillColor="#FF1744"
            android:pathData="M47,56.5 h2 v13.5 h-2 z M59,56.5 h2 v13.5 h-2 z" />

