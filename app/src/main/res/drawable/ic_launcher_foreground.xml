        </path>
        <!-- Right Pillar -->
        <path
            android:pathData="M80,44 L84,44 L84,70 L80,70 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="80"
                    android:startY="44"
                    android:endX="84"
                    android:endY="70"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#2979FF" />
                    <item android:offset="1.0" android:color="#1A237E" />
                </gradient>
            </aapt:attr>
        </path>

