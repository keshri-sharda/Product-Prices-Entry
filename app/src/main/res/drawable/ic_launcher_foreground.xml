                <gradient
                    android:startX="71"
                    android:startY="32"
                    android:endX="88"
                    android:endY="44"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#2979FF" />
                    <item android:offset="1.0" android:color="#1565C0" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- 4. FRIENDLY SHOPKEEPER (Cute, friendly avatar behind the counter) -->
