        <path
            android:strokeColor="#FFFFFF"
            android:strokeWidth="1.2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M80,47 Q75,52 73,56.5" />

        <!-- 7. SPARKLES & GRAPHIC COMPASS STARS (To radiate creative visual polish) -->
        <path
            android:fillColor="#00E5FF"
            android:pathData="M26,24 L27,27 L30,28 L27,29 L26,32 L25,29 L22,28 L25,27 Z" />
        <path
            android:fillColor="#FF5252"
            android:pathData="M82,24 L83,27 L86,28 L83,29 L82,32 L81,29 L78,28 L81,27 Z" />
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M54,14 L55,17 L58,18 L55,19 L54,22 L53,19 L50,18 L53,17 Z" />

